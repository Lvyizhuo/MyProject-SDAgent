# 环境变量配置文件示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 阿里云 DashScope API 配置（必需）
# ============================================
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ============================================
# 数据库配置（可选，默认使用 docker-compose 配置）
# ============================================
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=policy_agent
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# ============================================
# Redis 配置（可选，默认使用 docker-compose 配置）
# ============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ============================================
# Tavily Search API 配置（联网搜索功能）
# ============================================
# 获取地址: https://tavily.com (免费 1000 次/月)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ============================================
# 应用配置（可选）
# ============================================
# SERVER_PORT=8080
# SPRING_PROFILES_ACTIVE=dev

# ============================================
# 日志级别（可选）
# ============================================
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_SHANDONG=DEBUG
