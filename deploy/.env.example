# ===========================================
# 生产环境变量模板（部署到阿里云服务器）
# 用法: cp .env.example .env && vi .env
# ===========================================

# 必填：阿里云 DashScope Key
DASHSCOPE_API_KEY=your-dashscope-api-key

# 可选：联网搜索（不需要可留空）
TAVILY_API_KEY=

# 强烈建议改成高强度随机值
POSTGRES_PASSWORD=replace-with-strong-password
MINIO_USER=minioadmin
MINIO_PASSWORD=replace-with-strong-password

# 强烈建议改成新的 Base64 密钥
# 示例生成: openssl rand -base64 48
APP_JWT_SECRET=replace-with-base64-secret

# 可选但推荐：模型管理 API Key 加密主密钥（不配置时会回退使用 APP_JWT_SECRET）
APP_MODEL_PROVIDER_ENCRYPTION_SECRET=

# 可选：历史加密密钥兼容列表（逗号分隔，用于平滑轮换）
APP_MODEL_PROVIDER_LEGACY_ENCRYPTION_SECRETS=

# 你的正式域名（用于 CORS 放行）
APP_SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://mmgg.dpdns.org,https://mmgg.dpdns.org

# 可选：覆盖 Ollama 嵌入服务地址（容器内默认无需改）
APP_EMBEDDING_OLLAMA_BASE_URL=http://ollama:11434

# 可选：容器时区
TZ=Asia/Shanghai
